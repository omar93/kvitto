# Dependencies
node_modules/

# Build output
.svelte-kit/
build/
dist/

# Secrets / credentials — never commit
*.key.json
service-account*.json
credentials*.json
.env
.env.*
!.env.example

# Local app data
data/
*.local.json

# Real receipt files may contain card/loyalty numbers — keep them out of git.
# Commit a redacted *.txt + *.expected.json instead (see fixtures/receipts/README.md).
fixtures/receipts/*.pdf
fixtures/receipts/*.png
fixtures/receipts/*.jpg
fixtures/receipts/*.jpeg
fixtures/receipts/*.webp

# OS / editor
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
